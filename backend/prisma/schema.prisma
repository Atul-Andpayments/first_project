// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


enum RefundStatus{
  PENDING
  SUCCESS
  FAILED
}
enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}
model Merchant {
  id String @id @default(cuid())
  name String 
  email String @unique
  password String
  phone String @unique
  payments Payment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt 
}

model Payment {
  id            String        @id @default(cuid())

  customerName  String
  email         String?
  phone         String?

  amount        Decimal       @db.Decimal(12,2)

  description   String?

  status        PaymentStatus @default(PENDING)

  paymentUrl    String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  expiresAt     DateTime?
  paidAt        DateTime?

  merchantId    String
  merchant      Merchant      @relation(fields: [merchantId], references: [id])
  refunds       Refund[]
}

model Refund {
  id String @id @default(cuid())
  amount Decimal
  reason String?
  status RefundStatus
  paymentId String
  payment Payment @relation(fields: [paymentId],references:[id])
  createdAt DateTime @default(now())
}